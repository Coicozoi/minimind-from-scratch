```python
def sort_list(lst, reverse=False):
    """
    排序列表函数
    :param lst: 待排序的列表
    :param reverse: 是否降序排序，默认为 False，表示升序排序
    :return: 排序后的列表
    """
    return sorted(lst, reverse=reverse)
```
